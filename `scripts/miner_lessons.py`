def create_lesson_file(lesson_data: Dict[str, Any]) -> str:
    """
    Creates a YAML lesson file based on the repository's template structure.
    """
    # Construct the filename
    safe_title = "".join(c if c.isalnum() or c in (' ', '-') else '_' for c in lesson_data['title'])
    filename = f"{lesson_data['id']}_{safe_title.replace(' ', '_').lower()}.yml"
    filepath = OUTPUT_DIR / filename

    # Map to the expected YAML structure (based on typical lesson templates)
    lesson_yaml = {
        "id": lesson_data['id'],
        "title": lesson_data['title'],
        "date": datetime.now().strftime("%Y-%m-%d"),
        "author": "MisakaNet Miner Agent",
        "tags": lesson_data['tags'],
        "content": {
            "error_context": lesson_data['error_context'],
            "root_cause": lesson_data['root_cause'],
            "solution": lesson_data['solution'],
            "lesson_learned": lesson_data['lesson_learned']
        },
        "status": "draft" # Ready for review
    }

    # Write to file
    with open(filepath, 'w', encoding='utf-8') as f:
        yaml.dump(lesson_yaml, f, default_flow_style=False, sort_keys=False, allow_unicode=True)
    
    return str(filepath)

def main():
    print(f"🚀 Starting MisakaNet Lesson Miner...")
    print(f"📂 Output Directory: {OUTPUT_DIR}")
    
    # 1. Collect (Simulated)
    logs = get_sample_error_logs()
    print(f"📝 Collected {len(logs)} error-fix pairs.")

    # 2. Process & Convert
    created_files = []
    for i, log in enumerate(logs, 1):
        print(f"   Converting lesson {i}/{len(logs)}: {log['title']}")
        filepath = create_lesson_file(log)
        created_files.append(filepath)

    # 3. Summary
    print("\n✅ Mining Complete!")
    print(f"Generated {len(created_files)} lesson files:")
    for f in created_files:
        print(f"   - {f}")
    
    print("\n💡 Next Steps:")
    print("   1. Review the generated files in the 'lessons' folder.")
    print("   2. Commit and push to create a Pull Request.")
    print("   3. Tag the issue to claim the bounty.")

if __name__ == "__main__":
    main()