# FIX: Reconfigure stdout/stderr to utf-8 with errors='replace' to avoid UnicodeEncodeError on Windows
import sys

if sys.platform == "win32":
    # On Windows, default console encoding (e.g., cp936) cannot handle emoji.
    # Reconfiguring ensures print() works without crashing.
    sys.stdout.reconfigure(encoding='utf-8', errors='replace')
    sys.stderr.reconfigure(encoding='utf-8', errors='replace')

